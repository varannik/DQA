DATABASE_URL=postgresql://datasentinel:datasentinel_dev@localhost:5432/datasentinel
SECRET_KEY=dev-secret-key-change-in-production
INTERNAL_MESSAGE_SIGNING_KEY=dev-internal-signing-key-change-in-production
ENVIRONMENT=development
UPLOAD_DIR=./uploads
AWS_REGION=eu-west-1

# Leave empty for local filesystem mode
S3_DATASETS_BUCKET=
S3_MODELS_BUCKET=
SQS_DQA_REQUESTED_URL=
SQS_DQA_COMPLETED_URL=
SQS_CORRECTION_REQUESTED_URL=
SQS_CORRECTION_COMPLETED_URL=
SQS_AI_PREDICT_REQUESTED_URL=
SQS_AI_TRAINING_TRIGGERED_URL=

# inprocess | sqs
DQA_EXECUTION_MODE=inprocess
CORRECTION_EXECUTION_MODE=inprocess
